                    <button type="button" id="mobileMenuBtn" class="md:hidden p-2" aria-label="Open mobile menu">
                        <i class="fas fa-bars text-gray-600 dark:text-gray-300"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Mobile Menu -->
        <div id="mobileMenu" class="hidden md:hidden fixed inset-x-0 top-[4rem] max-h-[calc(100vh-4rem)] overflow-y-auto bg-white dark:bg-gray-800 border-t dark:border-gray-700 z-50">
            <div class="px-4 py-3 space-y-2">
                <a href="#about" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">About</a>
                <a href="#experience" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Experience</a>
                <a href="#academic" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Academic</a>
                <a href="#research" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Research</a>
                <a href="#publications" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Publications</a>
                <a href="#events" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Events</a>
                <a href="#gallery" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Gallery</a>
                <a href="#links" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Collections</a>
                <a href="#updates" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Updates</a>
                <a href="#contact" class="block py-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Contact</a>
            </div>
        </div>
    </nav>

    <div class="pt-16 lg:flex lg:min-h-screen">
        <!-- Left Sidebar / About -->
        <aside class="w-full lg:w-[24rem] xl:w-[28rem] lg:shrink-0 lg:block">
            <section id="about" class="lg:sticky lg:top-16 lg:flex lg:items-center lg:h-[calc(100vh-4rem)] theme-about-panel transition-colors duration-300">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
                    <div class="flex flex-col items-center justify-center gap-5 rounded-[2rem] border p-6 shadow-xl backdrop-blur-sm theme-card text-center">
                <!-- Profile Photo -->
                <div class="md:col-span-1 flex justify-center">
                    <div class="relative">
                        <div class="w-36 h-36 md:w-44 md:h-44 rounded-full overflow-hidden shadow-2xl border-4 border-white dark:border-gray-700 transition-colors duration-300">
                            <img id="profilePhoto" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=400&fit=crop" alt="Profile" class="w-full h-full object-cover">
                        </div>
                        <div class="absolute -bottom-2 -right-2 bg-accent-500 text-white p-3 rounded-full shadow-lg">
                            <i class="fas fa-graduation-cap text-xl"></i>
                        </div>
                    </div>
                </div>
                <!-- Profile Info -->
                <div class="md:col-span-2 text-center">
                    <h1 id="profileName" class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white font-serif mb-1">Dr. Sarah Chen</h1>
                    <p id="profileTitle" class="text-lg text-primary-600 dark:text-primary-400 font-medium mb-3">Senior Research Scientist in Computational Biology</p>

                    <!-- Expertise Keywords -->
                    <div id="expertiseKeywords" class="flex flex-wrap justify-center gap-2 mb-3">
                        <span class="keyword-chip px-3 py-1 rounded-full text-sm text-primary-700 dark:text-primary-300">Machine Learning</span>
                        <span class="keyword-chip px-3 py-1 rounded-full text-sm text-primary-700 dark:text-primary-300">Bioinformatics</span>
                        <span class="keyword-chip px-3 py-1 rounded-full text-sm text-primary-700 dark:text-primary-300">Genomics</span>
                        <span class="keyword-chip px-3 py-1 rounded-full text-sm text-primary-700 dark:text-primary-300">Systems Biology</span>
                    </div>

                    <p id="profileBio" class="text-gray-600 dark:text-gray-300 leading-relaxed mb-4 max-w-2xl mx-auto text-sm md:text-base">
                        Leading interdisciplinary research at the intersection of artificial intelligence and molecular biology. 
                        Focused on developing computational methods to understand complex biological systems and disease mechanisms.
                    </p>

