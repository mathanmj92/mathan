                        </div>
                        <div class="bg-white dark:bg-gray-700 rounded-xl p-2.5 shadow-lg card-hover transition-colors duration-300 flex flex-col items-center justify-center text-center min-h-[70px]">
                            <div class="text-xl font-bold gradient-text metric-counter leading-none" id="metricHIndex">28</div>
                            <div class="text-[11px] text-gray-500 dark:text-gray-400 mt-1">h-index</div>
                        </div>
                        <div class="bg-white dark:bg-gray-700 rounded-xl p-2.5 shadow-lg card-hover transition-colors duration-300 flex flex-col items-center justify-center text-center min-h-[70px]">
                            <div class="text-xl font-bold gradient-text metric-counter leading-none" id="metricI10Index">42</div>
                            <div class="text-[11px] text-gray-500 dark:text-gray-400 mt-1">i10-index</div>
                        </div>
                        <div class="bg-white dark:bg-gray-700 rounded-xl p-2.5 shadow-lg card-hover transition-colors duration-300 flex flex-col items-center justify-center text-center min-h-[70px]">
                            <div class="text-xl font-bold gradient-text metric-counter leading-none" id="metricPublications">56</div>
                            <div class="text-[11px] text-gray-500 dark:text-gray-400 mt-1">Publications</div>
                        </div>
                    </div>
                    </div>
                </div>
            </section>
        </aside>

        <!-- Right Content -->
        <div class="flex-1 lg:h-screen lg:overflow-y-auto">
            <!-- Work Experience Section -->
    <section id="experience" class="py-16 bg-white dark:bg-gray-800 transition-colors duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
