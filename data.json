<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academic Research Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        accent: {
                            50: '#fdf4ff',
                            100: '#fae8ff',
                            200: '#f5d0fe',
                            300: '#f0abfc',
                            400: '#e879f9',
                            500: '#d946ef',
                            600: '#c026d3',
                            700: '#a21caf',
                            800: '#86198f',
                            900: '#701a75',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .gradient-text {
            background: linear-gradient(135deg, #1e40af 0%, #7c3aed 50%, #c026d3 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.15);
        }
        .metric-counter {
            font-variant-numeric: tabular-nums;
        }
        .gallery-overlay {
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
        }
        .publication-tag {
            transition: all 0.2s ease;
        }
        .publication-tag:hover {
            transform: scale(1.05);
        }
        .smooth-fade {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .modal-enter {
            animation: modalIn 0.3s ease-out;
        }
        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        .timeline-line {
            position: absolute;
            left: 24px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #2563eb, #7c3aed);
        }
        .keyword-chip {
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(124, 58, 237, 0.1));
            border: 1px solid rgba(37, 99, 235, 0.2);
        }
        .status-ongoing {
            background: linear-gradient(135deg, #10b981, #059669);
        }
        .status-published {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
        }
        .category-article {
            background: #dbeafe;
            color: #1e40af;
        }
        .category-book_chapter {
            background: #fce7f3;
            color: #a21caf;
        }
        .category-patent {
            background: #fef3c7;
            color: #92400e;
        }
        .category-conference {
            background: #d1fae5;
            color: #065f46;
        }
        .event-type-invited_talk {
            background: #dbeafe;
            color: #1e40af;
        }
        .event-type-conference {
            background: #d1fae5;
            color: #065f46;
        }
        .event-type-workshop {
            background: #fef3c7;
            color: #92400e;
        }
        .event-type-seminar {
            background: #fce7f3;
            color: #a21caf;
        }
        :root {
            --site-bg: #f8fafc;
            --site-text: #1f2937;
            --site-surface: #ffffff;
            --site-surface-strong: #f3f4f6;
            --site-muted: #6b7280;
            --site-gradient-from: #1e40af;
            --site-gradient-to: #7c3aed;
            --site-gradient-mid: #c026d3;
        }
        .dark {
            --site-bg: #0f172a;
            --site-text: #f8fafc;
            --site-surface: #111827;
            --site-surface-strong: #1f2937;
            --site-muted: #9ca3af;
            --site-gradient-from: #60a5fa;
            --site-gradient-to: #a78bfa;
            --site-gradient-mid: #f0abfc;
        }
        body {
            background-color: var(--site-bg);
            color: var(--site-text);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .gradient-text {
            background: linear-gradient(135deg, var(--site-gradient-from) 0%, var(--site-gradient-to) 50%, var(--site-gradient-mid) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .theme-about-panel {
            background: transparent;
        }
        .theme-card {
            background-color: var(--site-surface);
            border-color: color-mix(in srgb, var(--site-text) 12%, transparent);
            color: var(--site-text);
        }
        .theme-card .text-gray-500,
        .theme-card .text-gray-600,
        .theme-card .text-gray-700,
        .theme-card .text-gray-400 {
            color: var(--site-muted) !important;
        }
        .bg-white, .bg-gray-50, .bg-gray-100, .bg-gray-700, .bg-gray-800, .bg-gray-900 {
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .bg-white {
            background-color: var(--site-surface) !important;
            color: var(--site-text) !important;
        }
        .bg-gray-50 {
            background-color: var(--site-bg) !important;
            color: var(--site-text) !important;
        }
        .bg-gray-100 {
            background-color: var(--site-surface-strong) !important;
            color: var(--site-text) !important;
        }
        .bg-gray-700, .bg-gray-800, .bg-gray-900 {
            background-color: var(--site-surface-strong) !important;
            color: var(--site-text) !important;
        }
        .text-gray-500, .text-gray-600, .text-gray-700, .text-gray-400 {
            color: var(--site-muted) !important;
        }
        .text-gray-800, .text-gray-900, .text-gray-100 {
            color: var(--site-text) !important;
        }
        * {
            box-sizing: border-box;
        }
        html, body {
            min-height: 100vh;
            width: 100%;
            max-width: 100%;
            overflow-x: hidden;
        }
        img, svg, video, iframe {
            max-width: 100%;
            height: auto;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-800 dark:text-gray-100 font-sans antialiased transition-colors duration-300">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 lg:left-[24rem] xl:left-[28rem] lg:right-0 bg-white/90 dark:bg-gray-800/90 backdrop-blur-md shadow-sm dark:shadow-gray-900 z-50 transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
