            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-center md:items-end gap-4">
                    <div class="mb-4 md:mb-0 md:text-right">
                        <p class="text-gray-400 text-sm">
                            &copy; <span id="footerYear">2024</span> <span id="footerName">Dr. Sarah Chen</span>. All rights reserved.
                        </p>
                    </div>
                    <div id="footerSocialLinks" class="flex space-x-6 justify-end"></div>
                </div>
                <div class="mt-4 text-right text-gray-500 text-xs">
                    Last updated: <span id="lastUpdated">February 11, 2024</span>
                </div>
            </div>
        </footer>

        </div>
    </div>

    <!-- Research Detail Modal -->
    <div id="researchModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white dark:bg-gray-800 rounded-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto modal-enter transition-colors duration-300">
            <div class="p-6 md:p-8">
                <div class="flex justify-between items-start mb-4">
                    <h3 id="researchModalTitle" class="text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif pr-4">Research Details</h3>
                    <button id="closeResearchModal" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                        <i class="fas fa-times text-gray-500 dark:text-gray-400"></i>
                    </button>
                </div>
                <div id="researchModalContent" class="text-gray-600 dark:text-gray-300">
                    <p>Research project details would appear here...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Publication Detail Modal -->
    <div id="publicationModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white dark:bg-gray-800 rounded-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto modal-enter transition-colors duration-300">
            <div class="p-6 md:p-8">
                <div class="flex justify-between items-start mb-4">
                    <h3 id="modalTitle" class="text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif pr-4">Publication Details</h3>
                    <button id="closeModal" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                        <i class="fas fa-times text-gray-500 dark:text-gray-400"></i>
                    </button>
                </div>
                <div id="modalContent" class="text-gray-600 dark:text-gray-300">
                    <p>Publication details would appear here...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Gallery Modal -->
    <div id="galleryModal" class="fixed inset-0 bg-black/90 z-50 hidden flex items-center justify-center p-4">
        <button id="closeGalleryModal" class="absolute top-4 right-4 text-white hover:text-gray-300 transition-colors">
            <i class="fas fa-times text-2xl"></i>
        </button>
        <div class="max-w-5xl w-full">
            <img id="galleryModalImage" src="" alt="" class="w-full max-h-[80vh] object-contain rounded-lg">
            <div class="mt-4 text-white">
                <h3 id="galleryModalTitle" class="text-xl font-bold"></h3>
                <p id="galleryModalDescription" class="text-gray-300 mt-2"></p>
            </div>
        </div>
    </div>

    <script src="scripts.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const mobileMenu = document.getElementById('mobileMenu');

            if (!mobileMenuBtn || !mobileMenu) return;

            mobileMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                });
            });
        });

        // Research Filter
        const researchFilters = document.querySelectorAll('.research-filter');
        const researchItems = document.querySelectorAll('.research-item');

        researchFilters.forEach(filter => {
            filter.addEventListener('click', () => {
                // Update active state
                researchFilters.forEach(f => {
                    f.classList.remove('bg-primary-600', 'text-white', 'dark:bg-primary-700');
                    f.classList.add('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-200');
                });
                filter.classList.remove('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-200');
                filter.classList.add('bg-primary-600', 'text-white', 'dark:bg-primary-700');

                const filterValue = filter.getAttribute('data-filter');
                
                researchItems.forEach(item => {
                    if (filterValue === 'all' || item.getAttribute('data-status') === filterValue) {
                        item.style.display = 'block';
                        item.classList.add('smooth-fade');
                    } else {
                        item.style.display = 'none';
                        item.classList.remove('smooth-fade');
                    }
                });
            });
        });

        // Modal functionality
        const researchModal = document.getElementById('researchModal');
        const closeResearchModal = document.getElementById('closeResearchModal');
        const publicationModal = document.getElementById('publicationModal');
        const closeModal = document.getElementById('closeModal');
        const galleryModal = document.getElementById('galleryModal');
        const closeGalleryModal = document.getElementById('closeGalleryModal');

        closeResearchModal.addEventListener('click', () => {
            researchModal.classList.add('hidden');
        });

        closeModal.addEventListener('click', () => {
            publicationModal.classList.add('hidden');
        });

        closeGalleryModal.addEventListener('click', () => {
            galleryModal.classList.add('hidden');
        });

        // Close modals when clicking outside
        window.addEventListener('click', (e) => {
            if (e.target === researchModal) {
                researchModal.classList.add('hidden');
            }
            if (e.target === publicationModal) {
                publicationModal.classList.add('hidden');
            }
            if (e.target === galleryModal) {
                galleryModal.classList.add('hidden');
            }
        });

        // Gallery modal functionality
        const galleryItems = document.querySelectorAll('.gallery-item');
        const galleryModalImage = document.getElementById('galleryModalImage');
        const galleryModalTitle = document.getElementById('galleryModalTitle');
        const galleryModalDescription = document.getElementById('galleryModalDescription');

        galleryItems.forEach(item => {
            item.addEventListener('click', () => {
                const img = item.querySelector('img');
                const title = item.querySelector('h3').textContent;
                const desc = item.querySelector('p').textContent;
                
                galleryModalImage.src = img.src;
                galleryModalTitle.textContent = title;
                galleryModalDescription.textContent = desc;
                galleryModal.classList.remove('hidden');
            });
        });

        // Update footer year
        document.getElementById('footerYear').textContent = new Date().getFullYear();

        // Smooth scroll for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Navbar scroll effect
        let lastScroll = 0;
        const navbar = document.getElementById('navbar');

        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            
            if (currentScroll > 100) {
                navbar.classList.add('shadow-md');
            } else {
                navbar.classList.remove('shadow-md');
            }
            
            lastScroll = currentScroll;
        });
        // Load saved data or fallback to defaults
        function loadPortfolioData() {
            const savedData = localStorage.getItem('portfolioData');
            if (savedData) {
                portfolioData = JSON.parse(savedData);
            }
        }

        // Execute on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadPortfolioData();  // 1. Fetch latest data from storage
            renderPublicLinks();  // 2. Build the HTML cards on the page
        });
    </script>
</body>
</html>
